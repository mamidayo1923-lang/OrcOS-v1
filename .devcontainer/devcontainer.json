{
    "name": "OrcOS Development Environment",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer",
                "tamasfe.even-better-toml"
            ]
        }
    },
    // noVNC用のポート6080を自動的にポートフォワードする
    "forwardPorts": [6080],
    "portsAttributes": {
        "6080": {
            "label": "QEMU Display (noVNC)",
            "onAutoForward": "openPreview"
        }
    }
}